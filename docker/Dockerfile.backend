FROM golang:1.26-alpine AS builder

WORKDIR /build

RUN apk add --no-cache git

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o mongebot ./cmd/mongebot/

FROM alpine:3.21

WORKDIR /app

RUN apk add --no-cache ca-certificates ffmpeg tzdata

COPY --from=builder /build/mongebot .

RUN mkdir -p /app/data

EXPOSE 9800

ENTRYPOINT ["./mongebot"]
CMD ["--mode", "headless", "--port", "9800"]
