# MongeBot Environment Variables
# Copy this file to .env and adjust values as needed.
# Environment variables override config.json values.

# Run mode: sidecar (with API for Tauri) or headless (CLI only)
# MONGEBOT_MODE=sidecar

# API server settings
# MONGEBOT_API_PORT=9800
# MONGEBOT_API_HOST=127.0.0.1

# Logging
# MONGEBOT_LOG_LEVEL=info
# MONGEBOT_LOG_FILE=mongebot.log

# Engine defaults
# MONGEBOT_MAX_WORKERS=50
# MONGEBOT_PROXY_TIMEOUT=60s

# Default channel (for headless mode)
# MONGEBOT_CHANNEL=streamer_name

# Default platform (twitch, kick, youtube)
# MONGEBOT_PLATFORM=twitch

# Feature toggles (true/false)
# MONGEBOT_ENABLE_ADS=true
# MONGEBOT_ENABLE_CHAT=true
# MONGEBOT_ENABLE_PUBSUB=true
